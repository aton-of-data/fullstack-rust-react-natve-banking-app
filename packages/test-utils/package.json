{
  "name": "@ficus/test-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal shared test helpers for Ficus packages and apps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.{json,mjs}\""
  },
  "dependencies": {
    "@ficus/contracts": "workspace:*"
  },
  "devDependencies": {
    "@ficus/eslint-config": "workspace:*",
    "@ficus/typescript-config": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

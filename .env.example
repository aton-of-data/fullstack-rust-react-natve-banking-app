# API
API_HOST=0.0.0.0
API_PORT=8080
RUST_LOG=info,ficus_api=debug
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://ficus_app:ficus_app_password@localhost:5432/ficus
DATABASE_MIGRATION_URL=postgres://ficus_migrator:ficus_migrator_password@localhost:5432/ficus

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRY_SECS=3600

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Rate limiting
LOGIN_RATE_LIMIT_PER_MIN=10
TRANSFER_RATE_LIMIT_PER_MIN=30

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ficus-api
METRICS_ENABLED=true

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:8080
